# Generated by NKS WebDev Console — do not edit manually.
# Nginx server block for {{ site.domain }}

server {
    listen {{ port }};
    server_name {{ site.domain }}{{ for a in site.aliases }} {{ a }}{{ end }};

    root "{{ site.root | string.replace '\\' '/' }}";
    index index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }
}
