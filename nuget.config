<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- NKS Hub GitHub Packages feed — hosts NKS.WebDevConsole.Plugin.SDK
         published by the nks-ws monorepo's publish-sdk.yml workflow on
         every v* tag. Plugin csprojs reference the SDK via PackageReference;
         this source tells NuGet where to resolve it from. -->
    <add key="nks-hub-github" value="https://nuget.pkg.github.com/nks-hub/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <!-- GitHub Packages requires authentication even for public packages.
         CI workflows authenticate automatically via GITHUB_TOKEN.
         Local developers must export NUGET_GH_USERNAME + NUGET_GH_TOKEN
         (a PAT with read:packages scope) before running dotnet restore.
         Example: export NUGET_GH_USERNAME=lukyrys NUGET_GH_TOKEN=ghp_xxx -->
    <nks-hub-github>
      <add key="Username" value="%NUGET_GH_USERNAME%" />
      <add key="ClearTextPassword" value="%NUGET_GH_TOKEN%" />
    </nks-hub-github>
  </packageSourceCredentials>
</configuration>
